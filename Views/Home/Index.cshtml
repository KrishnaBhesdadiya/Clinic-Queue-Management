@{
	Layout = "_Layout";
}
@{
    ViewData["Title"] = "Health Check";
}
<style>
    /* Main teal button */
    .btn-teal-action {
        background-color: #0f6d63;
        color: white;
        border: none;
        border-radius: 8px; /* Matching the rounded look */
        padding: 8px 20px;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .btn-teal-action:hover {
            background-color: #0a4d46;
            color: white;
        }

    /* Gray secondary buttons */
    .btn-gray-action {
        background-color: #e9ecef;
        color: #495057;
        border: none;
        border-radius: 8px;
        padding: 8px 20px;
        font-weight: 500;
        transition: background-color 0.2s;
        margin-left: 5px;
    }

        .btn-gray-action:hover {
            background-color: #dee2e6;
            color: #212529;
        }
</style>
<main role="main" class="main p-4">
    <h3 class="fw-bold mb-4" style="color:#0f6d63">Patient Dashboard</h3>
    <div class="card shadow-sm border-0 mb-3" style="max-width: 800px; border-radius: 8px;">
        <div class="card-body p-4">

            <h5 class="fw-bold mb-3">
                Welcome
            </h5>
            <p class="text-muted mb-3">
				Use the menu to book an appointment, view your prescriptions, prescriptions or medical reports.
            </p>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button type="button" class="btn btn-teal-action" asp-action="Index" asp-controller="Home">
                    Book Appointment
                </button>

                <button type="button" class="btn btn-gray-action" asp-action="Index" asp-controller="Home">
                    My Appointments
                </button>

                <button type="button" class="btn btn-gray-action" asp-action="Index" asp-controller="Home">
                    My Prescriptions
                </button>

                <button type="button" class="btn btn-gray-action" asp-action="Index" asp-controller="Home">
                    My Reports
                </button>
            </div>
        </div>
    </div>
</main>